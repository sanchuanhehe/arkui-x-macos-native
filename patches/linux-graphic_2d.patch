+    int num = static_cast<int>(fitRangeArr.size());
+    for (int index = 0; index < num; ++index) {
+        napi_value tempValue = CreateFitRangeJsValue(env, fitRangeArr[index]);
+        napi_set_element(env, returnFitRangeArr, index, tempValue);
+    }
