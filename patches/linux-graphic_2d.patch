+napi_value CreateJsError(napi_env env, int32_t errCode, const std::string& message)
+{
+    napi_value result = nullptr;
+    napi_create_error(env, CreateJsValue(env, errCode), CreateJsValue(env, message), &result);
+    return result;
+}
