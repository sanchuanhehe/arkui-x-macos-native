-rosen_preview = rosen_is_mac || rosen_is_win || rosen_is_linux
+# Linux/Wayland native port (Route A): the arkui-x linux build does NOT take the
+# GLFW preview path — it renders client-side via EGL window surface (like Android,
+# ROSEN_ARKUI_X). Non-arkui-x linux (the standalone previewer) stays on preview.
+rosen_preview =
+    rosen_is_mac || rosen_is_win ||
+    (rosen_is_linux && !(defined(is_arkui_x) && is_arkui_x))
 
