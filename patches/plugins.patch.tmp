+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+
+#ifndef PLUGINS_FILE_PICKER_MACOS_PLUGIN_IMPL_H
+#define PLUGINS_FILE_PICKER_MACOS_PLUGIN_IMPL_H
+
+#include <string>
+#include <memory>
+#include <vector>
+#include "../native_document_view_picker.h"
+
+namespace OHOS::Plugin {
+
+    class DocumentFilePickerImpl final : public DocumentFilePicker {
+    public:
+        DocumentFilePickerImpl() {};
+        virtual ~DocumentFilePickerImpl() {};
+
+        napi_value select(napi_env env, DocumentSelectOptions&);
+        napi_value save(napi_env env, DocumentSaveOptions&);
+    };
+} // namespace OHOS::Plugin
+
+#endif // PLUGINS_FILE_PICKER_MACOS_PLUGIN_IMPL_H
diff --git a/file/picker/filepicker/macos/document_picker_impl.mm b/file/picker/filepicker/macos/document_picker_impl.mm
new file mode 100644
index 00000000..016fe11b
--- /dev/null
+++ b/file/picker/filepicker/macos/document_picker_impl.mm
@@ -0,0 +1,145 @@
+/*
+ * Copyright (c) 2026 Huawei Device Co., Ltd.
+ * Licensed under the Apache License, Version 2.0 (the "License");
+ * you may not use this file except in compliance with the License.
+ * You may obtain a copy of the License at
+ *
+ *     http://www.apache.org/licenses/LICENSE-2.0
+ *
+ * Unless required by applicable law or agreed to in writing, software
+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+
+// M4 file picker, macOS native impl. The iOS port presents a
+// UIDocumentPickerViewController; on macOS the natural equivalent is
+// NSOpenPanel (select) / NSSavePanel (save). Same contract: resolve the JS
+// Promise via DocumentFilePicker::onPickerResult(paths, errCode).
+
+#include "document_picker_impl.h"
+#include "utils/log.h"
+
+#import <AppKit/AppKit.h>
+#import <UniformTypeIdentifiers/UniformTypeIdentifiers.h>
+
+namespace OHOS::Plugin {
+namespace {
+constexpr int ERR_OK = 0;
+constexpr int ERR_CANCEL = -1;
+
+// Map a suffix filter token (".png", "png", or a UTI like "public.image")
+// to a UTType for NSOpenPanel.allowedContentTypes. Unknown tokens are ignored
+// (panel then allows all types), matching iOS's lenient behavior.
+UTType* ToUTType(const std::string& token) API_AVAILABLE(macos(11.0)) {
+    if (token.empty()) {
+        return nil;
+    }
+    NSString* s = [NSString stringWithUTF8String:token.c_str()];
+    // strip a leading dot/star — "*.png" / ".png" -> "png"
+    NSCharacterSet* trim = [NSCharacterSet characterSetWithCharactersInString:@"*."];
+    s = [s stringByTrimmingCharactersInSet:trim];
+    if (s.length == 0) {
+        return nil;
+    }
+    UTType* byExt = [UTType typeWithFilenameExtension:s];
+    if (byExt != nil) {
+        return byExt;
+    }
+    return [UTType typeWithIdentifier:s];
+}
+} // namespace
+
+napi_value DocumentFilePickerImpl::select(napi_env env, DocumentSelectOptions& options)
+{
+    HILOG_INFO("DocumentFilePickerImpl::select enter (macOS NSOpenPanel)");
+    DocumentFilePicker::napienv = env;
+    napi_value promise = nullptr;
+    DocumentFilePicker::deferred = nullptr;
+    napi_create_promise(env, &DocumentFilePicker::deferred, &promise);
+
+    // Snapshot options for the main-thread block.
+    int32_t maxSelect = options.maxSelectNumber > 0 ? options.maxSelectNumber : 1;
+    std::vector<std::string> suffixes = options.fileSuffixFilters;
+
+    dispatch_block_t presentPanel = ^{
+        NSOpenPanel* panel = [NSOpenPanel openPanel];
+        panel.canChooseFiles = YES;
+        panel.canChooseDirectories = NO;
+        panel.allowsMultipleSelection = (maxSelect > 1);
+        panel.resolvesAliases = YES;
+
+        if (@available(macOS 11.0, *)) {
+            NSMutableArray<UTType*>* types = [NSMutableArray array];
+            for (const auto& suf : suffixes) {
+                UTType* t = ToUTType(suf);
+                if (t != nil) {
+                    [types addObject:t];
+                }
+            }
+            if (types.count > 0) {
+                panel.allowedContentTypes = types;
+            }
+        }
+
+        NSModalResponse resp = [panel runModal];
+        std::vector<std::string> result;
+        int errCode = ERR_CANCEL;
+        if (resp == NSModalResponseOK) {
+            errCode = ERR_OK;
+            for (NSURL* url in panel.URLs) {
+                if (url.path.length > 0) {
+                    result.emplace_back([url.path UTF8String]);
+                }
+                if (static_cast<int32_t>(result.size()) >= maxSelect) {
+                    break;
+                }
+            }
+        }
+        DocumentFilePicker::onPickerResult(result, errCode);
+    };
+
+    if ([NSThread isMainThread]) {
+        presentPanel();
+    } else {
+        dispatch_async(dispatch_get_main_queue(), presentPanel);
+    }
+    return promise;
+}
+
+napi_value DocumentFilePickerImpl::save(napi_env env, DocumentSaveOptions& options)
+{
+    HILOG_INFO("DocumentFilePickerImpl::save enter (macOS NSSavePanel)");
+    DocumentFilePicker::napienv = env;
+    napi_value promise = nullptr;
+    DocumentFilePicker::deferred = nullptr;
+    napi_create_promise(env, &DocumentFilePicker::deferred, &promise);
+
+    std::string defaultName = options.newFileNames.empty() ? std::string() : options.newFileNames[0];
+
+    dispatch_block_t presentPanel = ^{
+        NSSavePanel* panel = [NSSavePanel savePanel];
+        panel.canCreateDirectories = YES;
+        if (!defaultName.empty()) {
+            panel.nameFieldStringValue = [NSString stringWithUTF8String:defaultName.c_str()];
+        }
+        NSModalResponse resp = [panel runModal];
+        std::vector<std::string> result;
+        int errCode = ERR_CANCEL;
+        if (resp == NSModalResponseOK && panel.URL.path.length > 0) {
+            errCode = ERR_OK;
+            result.emplace_back([panel.URL.path UTF8String]);
+        }
+        DocumentFilePicker::onPickerResult(result, errCode);
+    };
+
+    if ([NSThread isMainThread]) {
+        presentPanel();
+    } else {
+        dispatch_async(dispatch_get_main_queue(), presentPanel);
+    }
+    return promise;
+}
+
+} // namespace OHOS::Plugin
diff --git a/i18n/BUILD.gn b/i18n/BUILD.gn
index 3c57ece7..92be41fd 100644
--- a/i18n/BUILD.gn
+++ b/i18n/BUILD.gn
@@ -163,6 +163,22 @@ template("plugin_i18n_static") {
       deps += [ "//foundation/arkui/ace_engine/adapter/ios/build:intl" ]
       cflags_cc += [ "-faligned-allocation" ]
       defines += [ "ARK_UI_X" ]
+    } else if (platform == "mac") {
+      # mac/ provides OHOS::Plugin::I18N::Create() (reuses the Foundation-only
+      # iOS impl). i18n_addon.cpp also uses intl's number_format.h; only the
+      # include dir is needed (NOT a dep on intl_static_mac — both compile the
+      # shared I18n core LocaleInfo/PluralRules/icu_data, which would duplicate
+      # symbols when both are linked statically into ace_macos).
+      #
+      # locale_config_intl_ext.cpp supplies the 3 intl-specific LocaleConfig
+      # methods i18n's fork lacks, so intl can reuse i18n's LocaleConfig instead
+      # of its own (which would ODR-collide). See the file header for the full
+      # rationale.
+      sources += [ "mac/locale_config_intl_ext.cpp" ]
+      deps += [ "mac:i18n_plugin_mac" ]
+      include_dirs += [ "//plugins/intl/include" ]
+      cflags_cc += [ "-faligned-allocation" ]
+      defines += [ "ARK_UI_X" ]
     }
 
     subsystem_name = "plugins"
diff --git a/i18n/framework/icu_data.cpp b/i18n/framework/icu_data.cpp
index 086e9a36..190c7fe0 100644
--- a/i18n/framework/icu_data.cpp
+++ b/i18n/framework/icu_data.cpp
@@ -18,8 +18,16 @@
 #include "ucmndata.h"
 #include "unicode/utypes.h"
 #include "unicode/udata.h"
+#include "unicode/putil.h"
 
 #include <mutex>
+#if defined(MAC_PLATFORM)
+#include <string>
+#include <unistd.h>
+#include <fcntl.h>
+#include <sys/mman.h>
+#include <sys/stat.h>
+#endif
 
 extern "C" const DataHeader U_DATA_API U_ICUDATA_ENTRY_POINT;
 
@@ -37,7 +45,38 @@ void InitIcuData()
     if (status != 0) {
         return;
     }
-	UErrorCode err;
+    // Must be U_ZERO_ERROR on entry: ICU APIs no-op when handed a UErrorCode that
+    // is already a failure. Leaving it uninitialised (garbage) made
+    // udata_setCommonDataAfterClean silently skip.
+    UErrorCode err = U_ZERO_ERROR;
+#if defined(MAC_PLATFORM)
+    // On mac the build links ICU's stubdata (an empty U_ICUDATA_ENTRY_POINT, 0
+    // bytes), so handing it to ICU leaves it with no locale data and every
+    // DateTimeFormat/NumberFormat comes back empty. u_setDataDirectory alone is
+    // too late — libace touches ICU during startup, which locks the (stub) data
+    // source. Instead mmap the real 31MB icudt<ver>l.dat shipped next to the app
+    // (cwd is the resource root after the constructor chdir; package_app.sh stages
+    // it under ./icu/) and hand it to udata_setCommonDataAfterClean, whose
+    // AfterClean resets ICU's earlier binding before installing the real data.
+    char cwd[PATH_MAX] = {0};
+    if (getcwd(cwd, sizeof(cwd)) != nullptr) {
+        std::string path = std::string(cwd) + "/icu/icudt74l.dat";
+        int fd = open(path.c_str(), O_RDONLY);
+        if (fd >= 0) {
+            struct stat st {};
+            if (fstat(fd, &st) == 0 && st.st_size > 0) {
+                // Kept mapped for the process lifetime; ICU holds the pointer.
+                void* data = mmap(nullptr, static_cast<size_t>(st.st_size), PROT_READ,
+                    MAP_PRIVATE, fd, 0);
+                if (data != MAP_FAILED) {
+                    udata_setCommonDataAfterClean(data, &err);
+                }
+            }
+            close(fd);
+        }
+    }
+#else
     udata_setCommonDataAfterClean(&U_ICUDATA_ENTRY_POINT, &err);
+#endif
     status = 1;
 }
diff --git a/i18n/include/locale_config.h b/i18n/include/locale_config.h
index c5b34bb2..2c1f7deb 100644
--- a/i18n/include/locale_config.h
+++ b/i18n/include/locale_config.h
@@ -17,9 +17,9 @@
 
 #include <string>
 
-#include "i18n_types.h"
-#include "locale_info.h"
-#include "plugins/i18n/I18N.h"
+#include "i18n_types.h"
+#include "locale_info.h"
+#include "plugins/i18n/I18N.h"
 
 namespace OHOS {
 namespace Global {
@@ -33,6 +33,16 @@ public:
     static std::string GetSystemRegion();
     static std::string GetSystemTimezone();
     static bool Is24HourClock();
+#if defined(MAC_PLATFORM)
+    // mac-only: intl reuses i18n's LocaleConfig (the two forks ODR-collide when
+    // both are static-linked into the single ace_macos exe). These 3 methods are
+    // intl-specific (i18n's fork lacks them); implemented in
+    // mac/locale_config_intl_ext.cpp via the INTL plugin so intl's date/number/
+    // relative-time formatters keep their correct calendar/numbering behaviour.
+    static std::string GetSystemCalendar();
+    static std::string GetNumberingSystem();
+    static std::string GetSystemLocaleWithExtParam();
+#endif
     static bool IsRTL(const std::string &locale);
     static std::string GetDisplayLanguage(const std::string &language, const std::string &displayLocale,
         bool sentenceCase);
diff --git a/i18n/mac/BUILD.gn b/i18n/mac/BUILD.gn
new file mode 100644
index 00000000..795b81a0
--- /dev/null
+++ b/i18n/mac/BUILD.gn
@@ -0,0 +1,41 @@
+# Copyright (c) 2026 Huawei Device Co., Ltd.
+# Licensed under the Apache License, Version 2.0 (the "License");
+# you may not use this file except in compliance with the License.
+# You may obtain a copy of the License at
+#
+#     http://www.apache.org/licenses/LICENSE-2.0
+#
+# Unless required by applicable law or agreed to in writing, software
+# distributed under the License is distributed on an "AS IS" BASIS,
+# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+# See the License for the specific language governing permissions and
+# limitations under the License.
+
+import("//build/ohos.gni")
+import("//foundation/arkui/ace_engine/ace_config.gni")
+
+# macOS platform impl of OHOS::Plugin::I18N. The iOS impl (i18n_plugin.m +
+# i18n_plugin_impl.mm) is Foundation-only — NSLocale / NSTimeZone, no UIKit and
+# no IOS_PLATFORM #ifdef branches — so the exact same Objective-C++ sources
+# compile and behave identically on macOS. Reuse them rather than fork a copy.
+ohos_source_set("i18n_plugin_mac") {
+  sources = [
+    "//plugins/i18n/ios/i18n_plugin.m",
+    "//plugins/i18n/ios/i18n_plugin_impl.mm",
+  ]
+
+  defines = [ "MAC_PLATFORM" ]
+
+  configs = [ "$ace_root:ace_config" ]
+
+  cflags_objc = [
+    "-fvisibility=default",
+    "-fobjc-weak",
+  ]
+  cflags_objcc = cflags_objc
+
+  deps = [ "//plugins/interfaces/native:ace_plugin_util_mac" ]
+
+  subsystem_name = "plugins"
+  part_name = "i18n"
+}
diff --git a/i18n/mac/locale_config_intl_ext.cpp b/i18n/mac/locale_config_intl_ext.cpp
new file mode 100644
index 00000000..e9eb7b75
--- /dev/null
+++ b/i18n/mac/locale_config_intl_ext.cpp
@@ -0,0 +1,106 @@
+/*
+ * Copyright (c) 2026 Huawei Device Co., Ltd.
+ * Licensed under the Apache License, Version 2.0 (the "License");
+ * you may not use this file except in compliance with the License.
+ * You may obtain a copy of the License at
+ *
+ *     http://www.apache.org/licenses/LICENSE-2.0
+ *
+ * Unless required by applicable law or agreed to in writing, software
+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+
+// macOS-only LocaleConfig extension.
+//
+// On iOS each plugin is an isolated dylib, so plugins/i18n and plugins/intl can
+// each carry their own fork of OHOS::Global::I18n::LocaleConfig without colliding.
+// On macOS both plugins are static-linked into the single ace_macos executable,
+// where the two forks would produce duplicate symbols (same class, different
+// Plugin:: member type — I18N* vs INTL*). We resolve this by linking only i18n's
+// LocaleConfig and dropping intl's copies (see plugins/intl/BUILD.gn mac branch).
+//
+// intl's date/number/relative-time formatters call three LocaleConfig methods
+// that i18n's fork does not define: GetSystemCalendar / GetNumberingSystem /
+// GetSystemLocaleWithExtParam. This file supplies them, sourcing calendar and
+// numbering data from the INTL plugin (the iOS Foundation impl reused on mac),
+// so behaviour matches intl's original implementation.
+
+#include "locale_config.h"
+
+#include <map>
+#include <memory>
+
+#include "plugins/intl/INTL.h"
+
+namespace OHOS {
+namespace Global {
+namespace I18n {
+namespace {
+// Mirrors the IcuCalendarMap in plugins/intl/framework/locale_config.cpp: maps
+// the platform calendar id to its ICU "-ca-" extension keyword.
+const std::map<std::string, std::string> g_icuCalendarMap = {
+    { "gregorian", "gregory" },
+    { "ethiopicAmeteMihret", "ethiopic" },
+    { "ethiopicAmeteAlem", "ethioaa" },
+    { "islamicCivil", "islamic-civil" },
+    { "islamicTabular", "islamic-tbla" },
+    { "islamicUmmAlQura", "islamic-umalqura" },
+    { "republicOfChina", "roc" },
+};
+
+std::unique_ptr<Plugin::INTL>& IntlPlugin()
+{
+    static std::unique_ptr<Plugin::INTL> plugin = Plugin::INTL::Create();
+    return plugin;
+}
+} // namespace
+
+std::string LocaleConfig::GetSystemCalendar()
+{
+    auto& plugin = IntlPlugin();
+    if (!plugin) {
+        return "";
+    }
+    std::string calendar = plugin->GetSystemCalendar();
+    auto iter = g_icuCalendarMap.find(calendar);
+    if (iter != g_icuCalendarMap.end()) {
+        calendar = iter->second;
+    }
+    return calendar;
+}
+
+std::string LocaleConfig::GetNumberingSystem()
+{
+    auto& plugin = IntlPlugin();
+    if (!plugin) {
+        return "";
+    }
+    return plugin->GetNumberingSystem();
+}
+
+std::string LocaleConfig::GetSystemLocaleWithExtParam()
+{
+    std::string systemLocale = LocaleConfig::GetSystemLocale();
+    bool hasExtParam = false;
+
+    std::string systemNumberingSystem = LocaleConfig::GetNumberingSystem();
+    if (!systemNumberingSystem.empty()) {
+        systemLocale += "-u-nu-" + systemNumberingSystem;
+        hasExtParam = true;
+    }
+    std::string systemCalendar = LocaleConfig::GetSystemCalendar();
+    if (!systemCalendar.empty()) {
+        if (!hasExtParam) {
+            systemLocale += "-u";
+        }
+        systemLocale += "-ca-" + systemCalendar;
+    }
+
+    return systemLocale;
+}
+} // namespace I18n
+} // namespace Global
+} // namespace OHOS
diff --git a/interfaces/native/BUILD.gn b/interfaces/native/BUILD.gn
index e471723c..5573ee61 100644
--- a/interfaces/native/BUILD.gn
+++ b/interfaces/native/BUILD.gn
@@ -133,12 +133,20 @@ ohos_source_set("napi_common") {
     "${ability_runtime_cross_platform_path}/interfaces/inner_api/hilog:ability_cross_platform_hilog_config",
   ]
 
-  sources = [
-    "//foundation/appframework/ability/ability_runtime/cross_platform/frameworks/js/napi/napi_common/napi_common_util.cpp",
-    "//foundation/appframework/ability/ability_runtime/cross_platform/frameworks/js/napi/napi_common/napi_common_want.cpp",
-  ]
-
-  deps = [ "${ability_runtime_cross_platform_path}/interfaces/inner_api/want:cross_platform_want" ]
+  # On mac, ability_runtime already compiles napi_common_util.cpp/napi_common_want.cpp
+  # in its own napi_common target to the SAME .o output path. Recompiling them here
+  # trips gn "Duplicate output file". Reuse ability_runtime's target instead of
+  # recompiling; only non-mac platforms build the sources locally.
+  if (target_os == "mac") {
+    sources = []
+    deps = [ "${ability_runtime_cross_platform_path}/frameworks/js/napi/napi_common:napi_common" ]
+  } else {
+    sources = [
+      "//foundation/appframework/ability/ability_runtime/cross_platform/frameworks/js/napi/napi_common/napi_common_util.cpp",
+      "//foundation/appframework/ability/ability_runtime/cross_platform/frameworks/js/napi/napi_common/napi_common_want.cpp",
+    ]
+    deps = [ "${ability_runtime_cross_platform_path}/interfaces/inner_api/want:cross_platform_want" ]
+  }
 
   deps += [ "//plugins/libs/napi:napi_${target_os}" ]
 
@@ -149,5 +157,12 @@ ohos_source_set("napi_common") {
   }
 
   subsystem_name = "ability"
-  part_name = "ability_runtime"
+
+  # NOTICE-file collision: ability_runtime's part also emits this notice; use a
+  # distinct part_name on mac so the two don't write the same NOTICE.txt path.
+  if (target_os == "mac") {
+    part_name = "plugins"
+  } else {
+    part_name = "ability_runtime"
+  }
 }
diff --git a/intl/BUILD.gn b/intl/BUILD.gn
index 4ed6cd4b..ce32426c 100644
--- a/intl/BUILD.gn
+++ b/intl/BUILD.gn
@@ -65,6 +65,25 @@ template("plugin_intl_static") {
       deps += [ "android/java:intl_plugin_android_jni" ]
     } else if (platform == "ios") {
       deps += [ "ios:intl_plugin_ios" ]
+    } else if (platform == "mac") {
+      # mac/ provides OHOS::Plugin::INTL::Create() (reuses the Foundation-only
+      # iOS impl).
+      deps += [ "mac:intl_plugin_mac" ]
+
+      # i18n and intl both fork the shared OHOS::Global::I18n core (LocaleInfo /
+      # LocaleConfig / InitIcuData / Split / PluralRules). On iOS each plugin is
+      # an isolated dylib so the duplicate definitions never meet; on mac both
+      # are static-linked into the single ace_macos executable, so the dup
+      # definitions collide (37 duplicate symbols). The two forks are the same
+      # source modulo include style, so drop intl's copies and resolve these
+      # symbols against i18n_static_mac's (also linked into ace_macos).
+      sources -= [
+        "framework/locale_info.cpp",
+        "framework/locale_config.cpp",
+        "framework/icu_data.cpp",
+        "framework/plural_rules.cpp",
+        "framework/utils.cpp",
+      ]
     }
 
     subsystem_name = "plugins"
diff --git a/intl/framework/icu_data.cpp b/intl/framework/icu_data.cpp
index 086e9a36..1356f4f7 100644
--- a/intl/framework/icu_data.cpp
+++ b/intl/framework/icu_data.cpp
@@ -37,7 +37,11 @@ void InitIcuData()
     if (status != 0) {
         return;
     }
-	UErrorCode err;
+    // Must be U_ZERO_ERROR on entry: ICU APIs no-op when handed a UErrorCode that
+    // is already a failure. Leaving it uninitialised (garbage) made
+    // udata_setCommonDataAfterClean silently skip, so the embedded icudt*_dat was
+    // never registered and every DateTimeFormat/NumberFormat came back empty.
+    UErrorCode err = U_ZERO_ERROR;
     udata_setCommonDataAfterClean(&U_ICUDATA_ENTRY_POINT, &err);
     status = 1;
 }
