diff --git a/intl/ios/intl_plugin.h b/intl/ios/intl_plugin.h
index 2510f8f6..250f00ba 100644
--- a/intl/ios/intl_plugin.h
+++ b/intl/ios/intl_plugin.h
@@ -16,7 +16,11 @@
 #define INTL_IOS_INTL_PLUGIN_H
 
 #import <Foundation/Foundation.h>
+// UIKit is iOS-only. macOS reuses these Foundation-based sources but has no
+// UIKit; the single UIDevice use (getDeviceType) is guarded for MAC_PLATFORM.
+#if !defined(MAC_PLATFORM)
 #import <UIKit/UIKit.h>
+#endif
 
 NS_ASSUME_NONNULL_BEGIN
 
diff --git a/intl/ios/intl_plugin.m b/intl/ios/intl_plugin.m
index ea1bc9d1..1e63e2d0 100644
--- a/intl/ios/intl_plugin.m
+++ b/intl/ios/intl_plugin.m
@@ -68,6 +68,10 @@ -(NSString*)getNumberingSystem{
 }
 
 -(NSString*)getDeviceType{
+#if defined(MAC_PLATFORM)
+    // macOS is a desktop class device; UIDevice does not exist here.
+    return @"pc";
+#else
     NSString *deviceModel = [[UIDevice currentDevice] model];
     NSString *deviceType = @"phones";
     if ([deviceModel isEqualToString: @"iPhone"]) {
@@ -77,6 +81,7 @@ -(NSString*)getDeviceType{
         deviceType = @"tablet";
     }
     return deviceType;
+#endif
 }
 
 @end
diff --git a/intl/mac/BUILD.gn b/intl/mac/BUILD.gn
new file mode 100644
index 00000000..e9d8dad1
--- /dev/null
+++ b/intl/mac/BUILD.gn
@@ -0,0 +1,40 @@
+# Copyright (c) 2026 Huawei Device Co., Ltd.
+# Licensed under the Apache License, Version 2.0 (the "License");
+# you may not use this file except in compliance with the License.
+# You may obtain a copy of the License at
+#
+#     http://www.apache.org/licenses/LICENSE-2.0
+#
+# Unless required by applicable law or agreed to in writing, software
+# distributed under the License is distributed on an "AS IS" BASIS,
+# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+# See the License for the specific language governing permissions and
+# limitations under the License.
+
+import("//build/ohos.gni")
+import("//foundation/arkui/ace_engine/ace_config.gni")
+
+# macOS platform impl of OHOS::Plugin::INTL. Same rationale as i18n/mac: the iOS
+# intl_plugin.m / intl_plugin_impl.mm are Foundation-only with no UIKit or
+# IOS_PLATFORM branches, so they compile and run unchanged on macOS.
+ohos_source_set("intl_plugin_mac") {
+  sources = [
+    "//plugins/intl/ios/intl_plugin.m",
+    "//plugins/intl/ios/intl_plugin_impl.mm",
+  ]
+
+  defines = [ "MAC_PLATFORM" ]
+
+  configs = [ "$ace_root:ace_config" ]
+
+  cflags_objc = [
+    "-fvisibility=default",
+    "-fobjc-weak",
+  ]
+  cflags_objcc = cflags_objc
+
+  deps = [ "//plugins/interfaces/native:ace_plugin_util_mac" ]
+
+  subsystem_name = "plugins"
+  part_name = "intl"
+}
