diff --git a/i18n/mac/locale_config_intl_ext.cpp b/i18n/mac/locale_config_intl_ext.cpp
new file mode 100644
index 00000000..e9eb7b75
--- /dev/null
+++ b/i18n/mac/locale_config_intl_ext.cpp
@@ -0,0 +1,106 @@
+/*
+ * Copyright (c) 2026 Huawei Device Co., Ltd.
+ * Licensed under the Apache License, Version 2.0 (the "License");
+ * you may not use this file except in compliance with the License.
+ * You may obtain a copy of the License at
+ *
+ *     http://www.apache.org/licenses/LICENSE-2.0
+ *
+ * Unless required by applicable law or agreed to in writing, software
+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+
+// macOS-only LocaleConfig extension.
+//
+// On iOS each plugin is an isolated dylib, so plugins/i18n and plugins/intl can
+// each carry their own fork of OHOS::Global::I18n::LocaleConfig without colliding.
+// On macOS both plugins are static-linked into the single ace_macos executable,
+// where the two forks would produce duplicate symbols (same class, different
+// Plugin:: member type — I18N* vs INTL*). We resolve this by linking only i18n's
+// LocaleConfig and dropping intl's copies (see plugins/intl/BUILD.gn mac branch).
+//
+// intl's date/number/relative-time formatters call three LocaleConfig methods
+// that i18n's fork does not define: GetSystemCalendar / GetNumberingSystem /
+// GetSystemLocaleWithExtParam. This file supplies them, sourcing calendar and
+// numbering data from the INTL plugin (the iOS Foundation impl reused on mac),
+// so behaviour matches intl's original implementation.
+
+#include "locale_config.h"
+
+#include <map>
+#include <memory>
+
+#include "plugins/intl/INTL.h"
+
+namespace OHOS {
+namespace Global {
+namespace I18n {
+namespace {
+// Mirrors the IcuCalendarMap in plugins/intl/framework/locale_config.cpp: maps
+// the platform calendar id to its ICU "-ca-" extension keyword.
+const std::map<std::string, std::string> g_icuCalendarMap = {
+    { "gregorian", "gregory" },
+    { "ethiopicAmeteMihret", "ethiopic" },
+    { "ethiopicAmeteAlem", "ethioaa" },
+    { "islamicCivil", "islamic-civil" },
+    { "islamicTabular", "islamic-tbla" },
+    { "islamicUmmAlQura", "islamic-umalqura" },
+    { "republicOfChina", "roc" },
+};
+
+std::unique_ptr<Plugin::INTL>& IntlPlugin()
+{
+    static std::unique_ptr<Plugin::INTL> plugin = Plugin::INTL::Create();
+    return plugin;
+}
+} // namespace
+
+std::string LocaleConfig::GetSystemCalendar()
+{
+    auto& plugin = IntlPlugin();
+    if (!plugin) {
+        return "";
+    }
+    std::string calendar = plugin->GetSystemCalendar();
+    auto iter = g_icuCalendarMap.find(calendar);
+    if (iter != g_icuCalendarMap.end()) {
+        calendar = iter->second;
+    }
+    return calendar;
+}
+
+std::string LocaleConfig::GetNumberingSystem()
+{
+    auto& plugin = IntlPlugin();
+    if (!plugin) {
+        return "";
+    }
+    return plugin->GetNumberingSystem();
+}
+
+std::string LocaleConfig::GetSystemLocaleWithExtParam()
+{
+    std::string systemLocale = LocaleConfig::GetSystemLocale();
+    bool hasExtParam = false;
+
+    std::string systemNumberingSystem = LocaleConfig::GetNumberingSystem();
+    if (!systemNumberingSystem.empty()) {
+        systemLocale += "-u-nu-" + systemNumberingSystem;
+        hasExtParam = true;
+    }
+    std::string systemCalendar = LocaleConfig::GetSystemCalendar();
+    if (!systemCalendar.empty()) {
+        if (!hasExtParam) {
+            systemLocale += "-u";
+        }
+        systemLocale += "-ca-" + systemCalendar;
+    }
+
+    return systemLocale;
+}
+} // namespace I18n
+} // namespace Global
+} // namespace OHOS
