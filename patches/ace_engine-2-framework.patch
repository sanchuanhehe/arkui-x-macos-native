+// Run a preload-abc evaluation at most once per runtime. These framework abc modules
+// (stateMgmt / jsEnumStyle / arkCommon / arkComponent / ...) declare top-level lexical
+// bindings (const / class). On the cross-platform shared-runtime path the preload
+// helpers are reachable more than once for a single runtime (InitAceModule from a page
+// engine + PreloadAceModule on the shared global runtime). Re-evaluating then throws
+// "Duplicate identifier ..." which aborts func_main_0 and leaves the module's globals
+// (e.g. LogTag, stateMgmtConsole) half-initialized, later crashing form components in
+// observeComponentCreation2. Guard with a per-runtime sentinel on the global object
+// (each runtime has its own global, so a freshly created runtime still loads normally).
+template<typename EvalFn>
+inline bool PreloadAbcOnce(const shared_ptr<JsRuntime>& runtime, const char* sentinel, EvalFn&& evalFn)
+{
+    shared_ptr<JsValue> global = runtime->GetGlobal();
+    if (global != nullptr) {
+        shared_ptr<JsValue> loaded = global->GetProperty(runtime, sentinel);
+        if (loaded != nullptr && loaded->IsBoolean(runtime) && loaded->ToBoolean(runtime)) {
+            return true;
+        }
+    }
+    bool result = evalFn();
+    if (result && global != nullptr) {
+        global->SetProperty(runtime, sentinel, runtime->NewBoolean(true));
+    }
+    return result;
+}
