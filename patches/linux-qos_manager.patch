@@ -36,6 +36,19 @@ config("client_public_config") {
     "../../interfaces/inner_api/",
     "${target_gen_dir}",
   ]
+  if (is_arkui_x) {
+    # Cross-platform (incl. linux/Wayland) has no foundation/communication/ipc
+    # repo (ipc:ipc_core/ipc_single auto-gated off), so the IDL-generated
+    # *_proxy/*_types/*_stub that include "iremote_proxy.h" cannot resolve it.
+    # Use graphic_2d's platform/ipc_core mock: its IRemoteBroker derives from
+    # RefBase (unlike the ace_engine ipc_single mock), so sptr<IConcurrentTaskService>
+    # resolves DecStrongRef/IncStrongRef. ipc_single is kept after it for the
+    # remaining headers (message_parcel/iremote_stub) it doesn't provide.
+    include_dirs += [
+      "//foundation/graphic/graphic_2d/rosen/modules/platform/ipc_core",
+      "//foundation/arkui/ace_engine/test/mock/ohos_mock/ipc_single",
+    ]
+  }
 }
 
 ohos_source_set("concurrent_task_idl") {
