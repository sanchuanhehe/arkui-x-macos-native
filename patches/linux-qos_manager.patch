+    # [linux-port auto-gate] "ipc:ipc_core",
   ]
   cflags_cc = [
     "-fomit-frame-pointer",
@@ -92,7 +105,17 @@ ohos_shared_library("concurrent_task_client") {
 
   sources = [ "src/concurrent_task_client.cpp" ]
 
-  sources += filter_include(output_values, [ "*_proxy.cpp" ])
+  if (is_arkui_x) {
+    # Cross-platform (incl. linux/Wayland) has no foundation/communication/ipc:
+    # the IDL-generated *_proxy.cpp uses real MessageOption(TF_ASYNC)/Remote()/
+    # SendRequest that the ace_engine ipc_single mock cannot provide. TryConnect()
+    # is stubbed under CROSS_PLATFORM (see src/concurrent_task_client.cpp), so the
+    # proxy is never referenced; drop it from the build. (*_types.cpp compiles
+    # against the mock and is kept.) No arkui-x target links this lib.
+    defines = [ "CROSS_PLATFORM" ]
+  } else {
+    sources += filter_include(output_values, [ "*_proxy.cpp" ])
+  }
   sources += filter_include(output_values, [ "*_types.cpp" ])
 
   deps = [ ":qos_manager_interface" ]
@@ -100,9 +123,9 @@ ohos_shared_library("concurrent_task_client") {
   external_deps = [
     "c_utils:utils",
     "hilog:libhilog",
-    "ipc:ipc_core",
-    "ipc:ipc_single",
-    "samgr:samgr_proxy",
+    # [linux-port auto-gate] "ipc:ipc_core",
+    # [linux-port auto-gate] "ipc:ipc_single",
+    # [linux-port auto-gate] "samgr:samgr_proxy",
   ]
 
   subsystem_name = "resourceschedule"
