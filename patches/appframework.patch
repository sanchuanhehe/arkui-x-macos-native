+class RSVsyncClientIOS : public RSVsyncClient {
+public:
+    RSVsyncClientIOS();
+    ~RSVsyncClientIOS() override;
+
+    void RequestNextVsync() override;
+    void SetVsyncCallback(VsyncCallback callback) override;
+
+private:
+    // Phase 1 path X: opaque handle to a C++ MacVsyncDriver (CVDisplayLink owner)
+    // instead of the ObjC RSVsyncIOS used on iOS.
+    void* vsyncIOS_ = nullptr;
