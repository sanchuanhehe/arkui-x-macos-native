+    "CoreMedia.framework",
+    "CoreVideo.framework",
+    "OpenGL.framework",
+    "QuartzCore.framework",
+    "Foundation.framework",
+  ]
+
+  public_deps = [
+    "$rosen_root/modules/platform:ace_skia",
+    "$rosen_root/modules/platform:eventhandler",
+    "$rosen_root/modules/platform:ipc_core",
+    "$rosen_root/modules/platform:utils",
