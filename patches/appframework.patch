+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+
+// Phase 1 path X: macOS vsync driver. iOS used CADisplayLink (fires on the main
+// run loop). macOS has no CADisplayLink for arbitrary layers (CADisplayLink for
+// NSView only exists on macOS 14+); the portable desktop equivalent is
+// CVDisplayLink, whose callback fires on a dedicated high-priority thread. We
+// keep the same "one-shot per RequestNextVsync" semantics: stop the link after
+// each callback, restart it on the next request.
+
+#include "rs_vsync_client_ios.h"
+
+#include <chrono>
+#include <mutex>
+#include <Foundation/Foundation.h>
+#include <CoreVideo/CoreVideo.h>
+
+#include "common/rs_common_def.h"
+#include "platform/common/rs_log.h"
+
+/* the coefficient of converting seconds to nanoseconds */
+constexpr int64_t SEC_TO_NANOSEC = 1000000000;
+
+namespace OHOS {
+namespace Rosen {
+
+// Lightweight C++ wrapper that owns a CVDisplayLink and forwards ticks.
+class MacVsyncDriver {
+public:
+    MacVsyncDriver()
+    {
+        CVDisplayLinkCreateWithActiveCGDisplays(&displayLink_);
+        if (displayLink_ != nullptr) {
+            CVDisplayLinkSetOutputCallback(displayLink_, &MacVsyncDriver::OutputCallback, this);
+        }
+    }
+
+    ~MacVsyncDriver()
+    {
+        if (displayLink_ != nullptr) {
+            if (CVDisplayLinkIsRunning(displayLink_)) {
+                CVDisplayLinkStop(displayLink_);
+            }
+            CVDisplayLinkRelease(displayLink_);
+            displayLink_ = nullptr;
+        }
+    }
+
+    void RequestNextVsync()
+    {
+        if (displayLink_ != nullptr && !CVDisplayLinkIsRunning(displayLink_)) {
+            CVDisplayLinkStart(displayLink_);
+        }
+    }
+
+    void SetVsyncCallback(RSVsyncClient::VsyncCallback callback)
+    {
+        std::lock_guard<std::mutex> lock(mutex_);
+        callback_ = callback;
+    }
+
+    void Invalidate()
+    {
+        if (displayLink_ != nullptr && CVDisplayLinkIsRunning(displayLink_)) {
+            CVDisplayLinkStop(displayLink_);
+        }
+    }
+
+private:
+    static CVReturn OutputCallback(CVDisplayLinkRef /* displayLink */,
+        const CVTimeStamp* /* now */, const CVTimeStamp* /* outputTime */,
+        CVOptionFlags /* flagsIn */, CVOptionFlags* /* flagsOut */, void* context)
+    {
+        auto* self = static_cast<MacVsyncDriver*>(context);
+        // One-shot semantics: stop after each tick, like CADisplayLink.paused = YES.
+        if (self->displayLink_ != nullptr) {
+            CVDisplayLinkStop(self->displayLink_);
+        }
+        struct timespec ts;
+        clock_gettime(CLOCK_MONOTONIC, &ts);
+        int64_t nowNs = ts.tv_sec * SEC_TO_NANOSEC + ts.tv_nsec;
+        RSVsyncClient::VsyncCallback cb;
+        {
+            std::lock_guard<std::mutex> lock(self->mutex_);
+            cb = self->callback_;
+        }
+        if (cb != nullptr) {
+            cb(nowNs, 0);
+        }
+        return kCVReturnSuccess;
+    }
+
+    CVDisplayLinkRef displayLink_ = nullptr;
+    RSVsyncClient::VsyncCallback callback_ = nullptr;
+    std::mutex mutex_;
+};
+
+std::unique_ptr<RSVsyncClient> RSVsyncClient::Create()
+{
+    return std::make_unique<RSVsyncClientIOS>();
+}
+
+RSVsyncClientIOS::RSVsyncClientIOS()
+    : vsyncIOS_(reinterpret_cast<void*>(new MacVsyncDriver()))
+{
+}
+
+RSVsyncClientIOS::~RSVsyncClientIOS()
+{
+    ROSEN_LOGI("RSVsyncClientIOS::dealloc (mac)");
+    auto* driver = reinterpret_cast<MacVsyncDriver*>(vsyncIOS_);
+    if (driver != nullptr) {
+        driver->Invalidate();
+        delete driver;
+        vsyncIOS_ = nullptr;
+    }
+}
+
+void RSVsyncClientIOS::RequestNextVsync()
+{
+    auto* driver = reinterpret_cast<MacVsyncDriver*>(vsyncIOS_);
+    if (driver != nullptr) {
+        driver->RequestNextVsync();
+    }
+}
+
+void RSVsyncClientIOS::SetVsyncCallback(VsyncCallback callback)
+{
+    auto* driver = reinterpret_cast<MacVsyncDriver*>(vsyncIOS_);
+    if (driver != nullptr) {
+        driver->SetVsyncCallback(callback);
+    }
+}
+} // namespace Rosen
+} // namespace OHOS
