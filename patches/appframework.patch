+const EGLContext RenderContextGL::GetResourceContext()
+{
+    std::lock_guard<std::mutex> lock(RenderContextGL::resourceContextMutex);
+    if (!RenderContextGL::resourceContext) {
+        RenderContextGL::resourceContext = CreateGLContext(nullptr);
+    }
+    return RenderContextGL::resourceContext;
+}
+
+bool RenderContextGL::Init()
+{
+    if (IsEglContextReady()) {
+        return true;
+    }
+    NSOpenGLContext* shareCtx = static_cast<NSOpenGLContext*>(GetResourceContext());
+    eglContext_ = CreateGLContext(shareCtx);
+    if (eglContext_ == nullptr) {
+        ROSEN_LOGE("eglContext_ is null");
+        return false;
+    }
+    color_space_ = Drawing::ColorSpace::CreateSRGB();
+    // macOS desktop: P3 wide-gamut detection is deferred to the window layer.
+
+    if (valid_) {
+        return false;
+    }
+
+    [static_cast<NSOpenGLContext*>(eglContext_) makeCurrentContext];
+    if ([NSOpenGLContext currentContext] != static_cast<NSOpenGLContext*>(eglContext_)) {
+        ROSEN_LOGE("Failed to set current OpenGL context");
+        return false;
+    }
+
+    glGenFramebuffers(1, &framebuffer_);
+    glBindFramebuffer(GL_FRAMEBUFFER, framebuffer_);
+    glGenRenderbuffers(1, &colorbuffer_);
+    glBindRenderbuffer(GL_RENDERBUFFER, colorbuffer_);
+    glFramebufferRenderbuffer(GL_FRAMEBUFFER, GL_COLOR_ATTACHMENT0, GL_RENDERBUFFER, colorbuffer_);
+    valid_ = true;
+    return true;
+}
+
+void RenderContextGL::MakeCurrent(EGLSurface surface, EGLContext context)
+{
+    [static_cast<NSOpenGLContext*>(eglContext_) makeCurrentContext];
+    CALayer* layer = static_cast<CALayer*>(surface);
+    if (layer == nullptr) {
+        return;
+    }
+    const CGSize layer_size = [layer bounds].size;
+    const CGFloat contents_scale = layer.contentsScale > 0 ? layer.contentsScale : 1.0;
+    const GLint size_width = static_cast<GLint>(layer_size.width * contents_scale);
+    const GLint size_height = static_cast<GLint>(layer_size.height * contents_scale);
+
+    if (layer == layer_ && size_width == storage_width_ && size_height == storage_height_) {
+        return;
+    }
+    ROSEN_LOGD("renderbufferStorage(desktop GL): %d x %d", size_width, size_height);
+
+    glBindFramebuffer(GL_FRAMEBUFFER, framebuffer_);
+    glBindRenderbuffer(GL_RENDERBUFFER, colorbuffer_);
+    // Desktop GL: allocate offscreen renderbuffer storage of the layer size.
+    glRenderbufferStorage(GL_RENDERBUFFER, GL_RGBA8, size_width, size_height);
+    glFramebufferRenderbuffer(GL_FRAMEBUFFER, GL_COLOR_ATTACHMENT0, GL_RENDERBUFFER, colorbuffer_);
+
+    storage_width_ = size_width;
+    storage_height_ = size_height;
+    if (layer_ != layer) {
+        [static_cast<CALayer*>(layer_) release];
+        layer_ = [layer retain];
+    }
+}
