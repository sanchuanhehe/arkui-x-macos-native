+// Phase 1 path X: native macOS desktop GL render context.
+// iOS bound a CAEAGLLayer directly to a GL renderbuffer via
+// -[EAGLContext renderbufferStorage:fromDrawable:]. macOS desktop GL has no such
+// API, so here we use an NSOpenGLContext (Core Profile) and render to an offscreen
+// FBO + renderbuffer color attachment sized from the target CALayer. The window
+// layer (adapter/macos, Phase 2) presents the FBO; this file owns only the GL
+// context + FBO and is the analogue of the EAGL path.
+
+#include "render_context/render_context.h"
+#include "render_context/new_render_context/render_context_gl.h"
+
+#include <MacTypes.h>
+#include <__config>
+#include <sstream>
+#include <chrono>
+#include <cmath>
+#include <AppKit/AppKit.h>
+#include <CoreFoundation/CoreFoundation.h>
+#include <OpenGL/OpenGL.h>
+#include <OpenGL/gl3.h>
+#include <OpenGL/gl3ext.h>
+#include <QuartzCore/QuartzCore.h>
+#include "rs_trace.h"
+#include "memory/rs_tag_tracker.h"
+#include "platform/common/rs_log.h"
+#ifdef RS_ENABLE_GL
+#include "platform/common/rs_system_properties.h"
+#endif
+
+namespace OHOS {
+namespace Rosen {
+std::mutex RenderContextGL::resourceContextMutex;
+EGLContext RenderContextGL::resourceContext = nullptr;
+constexpr size_t DEFAULT_SKIA_CACHE_SIZE        = 96 * (1 << 20);
+constexpr int DEFAULT_SKIA_CACHE_COUNT          = 2 * (1 << 12);
+
+// Build a Core Profile NSOpenGLContext, optionally sharing with |share|.
+static NSOpenGLContext* CreateGLContext(NSOpenGLContext* share)
+{
+    NSOpenGLPixelFormatAttribute attrs[] = {
+        NSOpenGLPFAAccelerated,
+        NSOpenGLPFAClosestPolicy,
+        NSOpenGLPFAOpenGLProfile, NSOpenGLProfileVersion3_2Core,
+        NSOpenGLPFAColorSize, 32,
+        NSOpenGLPFADepthSize, 0,
+        NSOpenGLPFAStencilSize, 8,
+        0
+    };
+    NSOpenGLPixelFormat* pf = [[[NSOpenGLPixelFormat alloc] initWithAttributes:attrs] autorelease];
+    if (pf == nullptr) {
+        return nullptr;
+    }
+    return [[NSOpenGLContext alloc] initWithFormat:pf shareContext:share];
+}
