+private:
+    HighContrastObserver() = default;
+    std::unordered_map<int32_t, HighContrastCallback> callbacks_;
+    ListenHighContrastCallback listenHighContrastCallback_;
+    bool highContrastState_ = false;
+    std::mutex mutex_;
+};
