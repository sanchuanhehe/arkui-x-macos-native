+        LOGE("Window: showWindow failed");
+        return WMError::WM_ERROR_INVALID_PARENT;
+    }
+
+    if ([windowView_ hide]) {
+        isWindowShow_ = false;
+        NotifyAfterBackground();
+        UpdateWindowStatus();
+        return WMError::WM_OK;
+    }
+
+    return WMError::WM_ERROR_INVALID_PARENT;
+}
