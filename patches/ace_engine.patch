+void Window::AddToWindowMap(std::shared_ptr<Window> window)
+{
+    DeleteFromWindowMap(window);
+    windowMap_.insert(std::make_pair(window->GetWindowName(),
+        std::pair<uint32_t, std::shared_ptr<Window>>(window->GetWindowId(), window)));
+}
