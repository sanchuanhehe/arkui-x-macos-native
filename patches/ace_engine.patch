+    }
+    auto deviceType = SystemProperties::GetDeviceType();
+    themeId = (deviceType == DeviceType::PHONE || deviceType == DeviceType::UNKNOWN || deviceType == DeviceType::CAR)
+                  ? THEME_ID_LIGHT
+                  : THEME_ID_DARK;
