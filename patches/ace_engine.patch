+DimensionUnit ParseDimensionUnit(const std::string& unit)
+{
+    if (unit == "px") {
+        return DimensionUnit::PX;
+    } else if (unit == "fp") {
+        return DimensionUnit::FP;
+    } else if (unit == "lpx") {
+        return DimensionUnit::LPX;
+    } else if (unit == "%") {
+        return DimensionUnit::PERCENT;
+    } else {
+        return DimensionUnit::VP;
