+void Window::RequestVsync(const std::shared_ptr<VsyncCallback>& vsyncCallback)
+{
+    static int n=0; if(n++<5) fprintf(stderr, "[DBG vsync] RequestVsync called, receiver_=%p\n", (void*)receiver_.get());
+    // stage model
+    if (receiver_) {
+        if(n<=5) fprintf(stderr, "[DBG vsync] -> RequestNextVSync issued\n");
+        auto callback = [vsyncCallback](int64_t timestamp, void*) {
+            static int m=0; if(m++<3) fprintf(stderr, "[DBG vsync] vsync FIRED ts=%lld\n", (long long)timestamp);
+            vsyncCallback->onCallback(timestamp, 0);
+        };
+        OHOS::Rosen::VSyncReceiver::FrameCallback fcb = {
+            .userData_ = this,
+            .callback_ = callback,
+        };
+        receiver_->RequestNextVSync(fcb);
+        return;
+    }
+}
+
+bool Window::CreateVSyncReceiver(std::shared_ptr<AppExecFwk::EventHandler> handler)
+{
+    if (receiver_) {
+        return true;
+    }
+    fprintf(stderr, "[DBG vsync] CreateVSyncReceiver called\n");
+    auto& rsClient = Rosen::RSInterfaces::GetInstance();
+    receiver_ = rsClient.CreateVSyncReceiver("Window_IOS", handler);
+    fprintf(stderr, "[DBG vsync] receiver created=%p\n", (void*)receiver_.get());
+    VsyncError ret = receiver_->Init();
+    if (ret) {
+        LOGE("Window_IOS: vsync receiver init failed: %{public}d", ret);
+        return false;
+    }
+    return true;
+}
+
+void Window::RequestNextVsync(std::function<void(int64_t, void*)> callback)
+{
+    if (!receiver_) {
+        return;
+    }
+    VSyncReceiver::FrameCallback fcb = {
+        .userData_ = this,
+        .callback_ = callback,
+    };
+    receiver_->RequestNextVSync(fcb);
+}
