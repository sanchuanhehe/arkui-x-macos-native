+WMError Window::GetAvoidAreaByType(AvoidAreaType type, AvoidArea& avoidArea) {
+    // macOS: no status bar / cutout / home indicator / keyboard avoid areas; return empty avoid area.
+    avoidArea.topRect_ = emptyRect;
+    avoidArea.leftRect_ = emptyRect;
+    avoidArea.rightRect_ = emptyRect;
+    avoidArea.bottomRect_ = emptyRect;
+
+    if (type == AvoidAreaType::TYPE_CUTOUT || type == AvoidAreaType::TYPE_KEYBOARD ||
+        type == AvoidAreaType::TYPE_SYSTEM || type == AvoidAreaType::TYPE_NAVIGATION_INDICATOR ||
+        type == AvoidAreaType::TYPE_SYSTEM_GESTURE) {
+        return WMError::WM_OK;
+    }
+    LOGE("GetAvoidAreaByType failed, AvoidAreaType is invalid");
+    return WMError::WM_ERROR_INVALID_PARAM;
+}
+} // namespace OHOS::Rosen
