+#include "display_info.h"
+
+#include <new>
+#include <parcel.h>
+// Phase 0 path X: macOS uses AppKit (NSScreen) instead of UIKit (UIScreen/UIDevice).
+#import <AppKit/AppKit.h>
+#import <sys/utsname.h>
+
+
+namespace OHOS::Rosen {
+
+DisplayInfo::DisplayInfo()
+{
+    id_ = 0;
+    // macOS has no device orientation; desktop displays are always landscape.
+    displayOrientation_ = DisplayOrientation::LANDSCAPE;
+
+    NSScreen* screen = [NSScreen mainScreen];
+    CGFloat scale = screen ? [screen backingScaleFactor] : 1.0;
+    NSRect frame = screen ? [screen frame] : NSMakeRect(0, 0, 0, 0);
+    width_ = static_cast<int32_t>(frame.size.width * scale);
+    height_ = static_cast<int32_t>(frame.size.height * scale);
+    densityPixels_ = scale;
+    scaledDensity_ = scale;
+    densityDpi_ = GetDevicePpi();
+}
+
+DisplayInfo::~DisplayInfo()
+{
+}
+
+DisplayId DisplayInfo::GetDisplayId() const
+{
+    return id_;
+}
