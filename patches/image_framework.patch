diff --git a/ide/image_decode_config.gni b/ide/image_decode_config.gni
index be093ae5a..eac70c731 100644
--- a/ide/image_decode_config.gni
+++ b/ide/image_decode_config.gni
@@ -20,17 +20,31 @@ declare_args() {
 
 # source code for Windows.
 use_mingw_win = "${current_os}_${current_cpu}" == "mingw_x86_64"
-use_clang_mac = "${current_os}_${current_cpu}" == "mac_x64"
+use_clang_mac = current_os == "mac"
 use_clang_ios = current_os == "ios" || current_os == "tvos"
 use_clang_android = current_os == "android"
 
 # Toolchain
 windows_buildtool = "//build/toolchain/mingw:mingw_x86_64"
-mac_buildtool = "//build/toolchain/mac:clang_x64"
+
+# Phase 2 path X: make mac_buildtool arch-aware so it agrees with the value
+# ace_config.gni computes (clang_arm64 on Apple Silicon). When both gni files are
+# imported into one scope (e.g. drawable_descriptor on arkui-x), gn requires the
+# values to be identical or it reports a "Value collision".
+if ("${current_os}_${current_cpu}" == "mac_arm64") {
+  mac_buildtool = "//build/toolchain/mac:clang_arm64"
+} else {
+  mac_buildtool = "//build/toolchain/mac:clang_x64"
+}
 
 # Defines
 image_decode_windows_defines = [ "_WIN32" ]
-image_decode_mac_defines = [ "_APPLE" ]
+# Phase 1 path X: mac also defines IOS_PLATFORM so the image_framework reuses
+# the iOS code branches (no OHOS system::/tokenid_kit on the desktop).
+image_decode_mac_defines = [
+  "_APPLE",
+  "IOS_PLATFORM",
+]
 image_decode_ios_defines = [ "IOS_PLATFORM" ]
 image_decode_android_defines = [ "ANDROID_PLATFORM" ]
 image_sep_f = "/f"
@@ -65,7 +79,19 @@ image_use_new_skia = image_framework_feature_upgrade_skia
 skia_root = "//third_party"
 skia_deps_root = skia_root
 skia_core = [ "$skia_deps_root/skia:skia_core" ]
-skia_skcms = [ "$skia_deps_root/skia:skcms" ]
+
+# Phase 0 path X (mac dedup): on target_os=mac route skcms through the m133
+# module static_library instead of the top-level "//third_party/skia:skcms"
+# source_set. Both compile the identical m133 skcms.cc into the SAME output
+# path, so keeping both target definitions makes ninja fail at load with
+# "multiple rules generate ... skcms.o". On mac we drop the top-level source_set
+# definition entirely (see third_party/skia/BUILD.gn), so every consumer must
+# point at the m133 target. Other platforms keep the original wiring.
+if (target_os == "mac") {
+  skia_skcms = [ "//third_party/skia/m133/modules/skcms:skcms" ]
+} else {
+  skia_skcms = [ "$skia_deps_root/skia:skcms" ]
+}
 
 exif_root = "//third_party"
 
