diff --git a/config/mac/BUILD.gn b/config/mac/BUILD.gn
index c3b9d0aa..a5a39f29 100644
--- a/config/mac/BUILD.gn
+++ b/config/mac/BUILD.gn
@@ -39,6 +39,26 @@ config("compiler") {
   asmflags = common_mac_flags
   cflags = common_mac_flags
 
+  # Phase 1 path X: Xcode's clang is newer than the prebuilt OHOS clang-15 and
+  # promotes several warnings to errors that the OHOS codebase trips on. Demote
+  # them so the desktop build compiles the existing sources unchanged.
+  cflags += [
+    "-Wno-error=deprecated-literal-operator",
+    "-Wno-error=unnecessary-virtual-specifier",
+    "-Wno-error=thread-safety-analysis",
+    "-Wno-error=thread-safety-reference-return",
+    "-Wno-error=vla-cxx-extension",
+    "-Wno-error=missing-template-arg-list-after-template-kw",
+    "-Wno-error=cast-function-type-mismatch",
+    "-Wno-error=nontrivial-memaccess",
+    "-Wno-error=c++11-narrowing-const-reference",
+    "-Wno-error=extra-qualification",
+    "-Wno-error=deprecated-declarations",
+    "-Wno-error=invalid-unevaluated-string",
+    "-Wno-error=enum-constexpr-conversion",
+    "-Wno-unknown-warning-option",
+  ]
+
   # Without this, the constructors and destructors of a C++ object inside
   # an Objective C struct won't be called, which is very bad.
   cflags_objcc = [ "-fobjc-call-cxx-cdtors" ]
