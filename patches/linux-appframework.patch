+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+
+// Linux/Wayland native port (Route A): the main-thread PlatformEventRunner for the
+// desktop client. iOS/android integrate with CFRunLoop/ALooper; on linux we drive
+// the ArkUI EventQueue with the standard epoll IoWaiter (epoll_io_waiter.cpp, already
+// compiled for linux). The Wayland display fd is added to the same epoll set by the
+// linux entrance, so UI events and ArkUI tasks share one loop. This mirrors the
+// device EventRunnerImpl blocking-drain loop and resolves PlatformEventRunner::{ctor,
+// dtor, Init, CheckCurrent} for ace_linux.
+
+#include "platform_event_runner.h"
+
+#include <sys/syscall.h>
+#include <thread>
+#include <unistd.h>
+
+#include "epoll_io_waiter.h"
+#include "event_handler.h"
+#include "event_queue.h"
+#include "event_runner.h"
+#include "hilog.h"
+
+namespace OHOS {
+namespace AppExecFwk {
+
+// On linux the main (initial) thread's kernel tid equals the process pid; this is the
+// thread that owns the platform (Wayland) message loop.
+bool PlatformEventRunner::CheckCurrent()
+{
+    return static_cast<pid_t>(syscall(SYS_gettid)) == getpid();
+}
+
+PlatformEventRunner::PlatformEventRunner(const std::shared_ptr<EventRunner>& runner)
+    : EventInnerRunner(runner)
+{
+    auto epollWaiter = std::make_shared<EpollIoWaiter>();
+    if (epollWaiter->Init()) {
+        queue_ = std::make_shared<EventQueue>(epollWaiter);
+    } else {
+        // Fall back to a queue with the default (none) io waiter so the runner is
+        // still usable for posted tasks even if epoll could not be set up.
+        HILOG_ERROR("PlatformEventRunner: EpollIoWaiter init failed, using default queue");
+        queue_ = std::make_shared<EventQueue>();
+    }
+    currentEventRunner = owner_;
+}
+
+PlatformEventRunner::~PlatformEventRunner()
+{
+    if (queue_) {
+        queue_->Finish();
+    }
+}
+
+void PlatformEventRunner::Run()
+{
+    queue_->Prepare();
+
+    if (owner_.expired()) {
+        return;
+    }
+
+    threadId_ = std::this_thread::get_id();
+
+    std::weak_ptr<EventRunner> oldRunner = currentEventRunner;
+    currentEventRunner = owner_;
+
+    for (auto event = queue_->GetEvent(); event; event = queue_->GetEvent()) {
+        std::shared_ptr<EventHandler> handler = event->GetOwner();
+        if (handler) {
+            handler->DistributeEvent(event);
+        }
+        event.reset();
+    }
+
+    currentEventRunner = oldRunner;
+}
+
+void PlatformEventRunner::Stop()
+{
+    if (queue_) {
+        queue_->Finish();
+    }
+}
+
+bool PlatformEventRunner::Init()
+{
+    threadId_ = std::this_thread::get_id();
+    queue_->Prepare();
+    return true;
+}
+
+} // namespace AppExecFwk
+} // namespace OHOS
