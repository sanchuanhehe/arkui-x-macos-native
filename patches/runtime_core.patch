-    sources = [ "${root_out_dir}/arkcompiler/stdlib" ]
-    outputs = [ ohos_ets_stdlib_path ]
-    part_name = "runtime_core"
-    subsystem_name = "arkcompiler"
+  # Phase 0 path X (mac dedup): ohos_ets_stdlib_path is a fixed $root_build_dir
+  # path; building it in both the default and host toolchains makes ninja fail
+  # with "multiple rules generate ...". Emit it only in the default toolchain.
+  if (current_toolchain == default_toolchain) {
+    ohos_copy("ohos_ets_stdlib") {
+      deps = [ ":copy_stdlib" ]
+      sources = [ "${root_out_dir}/arkcompiler/stdlib" ]
+      outputs = [ ohos_ets_stdlib_path ]
+      part_name = "runtime_core"
+      subsystem_name = "arkcompiler"
+    }
+  } else {
+    group("ohos_ets_stdlib") {
+      public_deps = [ ":ohos_ets_stdlib($default_toolchain)" ]
+    }
   }
 }
