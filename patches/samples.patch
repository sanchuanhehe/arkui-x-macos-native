+@Entry
+@Component
+struct SubPage {
+  build() {
+    Column({ space: 10 }) {
+      Text('🪟 子窗口').fontSize(22).fontWeight(FontWeight.Bold).fontColor(Color.White)
+      Text('拖动我移动位置').fontSize(15).fontColor('#FFEEEEEE')
