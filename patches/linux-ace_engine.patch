 import("preview_common.gni")
+import(
+    "//foundation/graphic/graphic_2d/rosen/modules/render_service_base/config.gni")
 
-# linux platform defines and configs
+# linux platform defines and configs.
+# Route A (Wayland native): the arkui-x linux build is the real desktop app
+# backend (client-side EGL, like Android), NOT the GLFW previewer. We therefore
+# drop the previewer's GPU_DISABLED / preview font-mgr and wire the native
+# adapter/linux targets, mirroring adapter/preview/build/config_mac.gni. The
+# standalone (non-arkui-x) linux previewer keeps the old preview config.
+linux_use_wayland_backend = defined(is_arkui_x) && is_arkui_x
+
+defines += [ "LINUX_PLATFORM" ]
+
+# bounds_checking_function securectype.h leaves SECUREC_ENABLE_SNPRINTF/VSNPRINTF
+# at 0 on non-MSVC; securec.h then hides snprintf_s/vsnprintf_s that many libace
+# TUs call. The bounds_checking lib implements them — just enable the decls.
 defines += [
-  "LINUX_PLATFORM",
-  "GPU_DISABLED",
-  "SK_BUILD_FONT_MGR_FOR_PREVIEW_LINUX",
+  "SECUREC_ENABLE_SNPRINTF=1",
+  "SECUREC_ENABLE_VSNPRINTF=1",
 ]
+
+if (!linux_use_wayland_backend) {
+  # Standalone GLFW previewer path (unchanged).
+  defines += [
+    "GPU_DISABLED",
+    "SK_BUILD_FONT_MGR_FOR_PREVIEW_LINUX",
+  ]
+} else {
+  # Native Wayland desktop backend (client-side EGL). Reuse the proven
+  # client-side (iOS-style) code branches like the mac port does; LINUX_PLATFORM
+  # carries the real Wayland/EGL/POSIX divergences (parallel to mac's
+  # MAC_PLATFORM). Real freetype+fontconfig is skia's native Linux path, so no
+  # preview font-mgr is needed.
+  build_for_preview = false
+  use_external_icu = "static"
+
+  defines += [
+    "IOS_PLATFORM",
+    "CROSS_PLATFORM",
+    "NG_BUILD",
+    "VIRTUAL_RS_WINDOW",
+    "ENABLE_ROSEN_BACKEND",
+    "QUICK_PUSH_TRANSITION",
+    "ACE_ENABLE_GL",
+    "SUPPORT_TOUCH_TARGET_TEST",
+  ]
+
+  # Replace the previewer platform_deps (set in preview_common.gni) with the
+  # native-linux adapter targets.
+  platform_deps = []
+  platform_deps = [
+    "//foundation/arkui/ace_engine/adapter/linux/entrance:ace_linux_entrance",
+    "//foundation/arkui/ace_engine/adapter/linux/osal:ace_osal_linux",
+    "//foundation/arkui/ace_engine/adapter/linux/stage/ability:stage_linux_entrance",
+    "//foundation/arkui/ace_engine/adapter/linux/stage/uicontent:ace_uicontent_linux",
+  ]
+
+  # libace_static_linux is generated by ace_engine/build/BUILD.gn's foreach over
+  # ace_platforms; the linux platform_deps above are pulled in via ace_lib.gni.
+  libace_target = "//foundation/arkui/ace_engine/build:libace_static_linux"
+
+  # PREVIEW (from preview_common.gni) makes JsMessageDispatcher::CallCurlFunction
+  # a pure virtual that AceContainerSG never implements; drop it for the native
+  # backend.
+  if (filter_include(defines, [ "PREVIEW" ]) != []) {
+    defines -= [ "PREVIEW" ]
+  }
+}
