diff --git a/interfaces/kits/rust/BUILD.gn b/interfaces/kits/rust/BUILD.gn
index 75c94d5..03dafb7 100644
--- a/interfaces/kits/rust/BUILD.gn
+++ b/interfaces/kits/rust/BUILD.gn
@@ -17,19 +17,35 @@ config("public_config") {
   include_dirs = [ "./include" ]
 }
 
-ohos_rust_shared_ffi("rust_file") {
-  crate_type = "cdylib"
-  part_name = "file_api"
-  subsystem_name = "filemanagement"
-  sources = [ "src/lib.rs" ]
-  crate_name = "rust_file"
-  rustflags = [ "-Zstack-protector=all" ]
-  deps = []
-  external_deps = [
-    "hilog:hilog_rust",
-    "rust_libc:lib",
-  ]
-
-  innerapi_tags = [ "platformsdk" ]
-  public_configs = [ ":public_config" ]
+# Linux/Wayland native port: the arkui-x build has no rust toolchain, so
+# ohos_rust_shared_ffi is undefined ("Unknown function"). The rust FFI is only
+# built for the ohos device; gate it so this file parses on the desktop client.
+# Linux/Wayland native port: the arkui-x linux build has no rust toolchain in any
+# toolchain context (default, host, or the mingw SDK cross-toolchain), so
+# ohos_rust_shared_ffi is always undefined here. `if (false)` reliably skips the
+# call in every context (current_os/is_arkui_x vary by toolchain and aren't
+# reliable). This is the linux-port branch; the rust FFI isn't needed.
+if (false) {
+  if (defined(is_arkui_x) && is_arkui_x) {
+    # [linux-port] no rust toolchain; empty stub so consumers resolve
+    group("rust_file") {
+    }
+  } else {
+    ohos_rust_shared_ffi("rust_file") {
+      crate_type = "cdylib"
+      part_name = "file_api"
+      subsystem_name = "filemanagement"
+      sources = [ "src/lib.rs" ]
+      crate_name = "rust_file"
+      rustflags = [ "-Zstack-protector=all" ]
+      deps = []
+      external_deps = [
+        "hilog:hilog_rust",
+        "rust_libc:lib",
+      ]
+  
+      innerapi_tags = [ "platformsdk" ]
+      public_configs = [ ":public_config" ]
+    }
+  }
 }
