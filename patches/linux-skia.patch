-        skia_feature_product == "tablet" ||
-        skia_feature_product == "wearable" || skia_feature_use_vulkan) {
+
+    # Linux/Wayland native port: the arkui-x desktop client renders via EGL/GLES
+    # (Android ROSEN_ARKUI_X client-side style), not Vulkan — the headless build has
+    # no vulkan_core.h and SK_VK_PARTIALRENDER also trips a missing <vector> include
