+    # Re-enabling custom_directory_factory here duplicates SkFontMgr::runtimeOS /
+    # containerFontPath (also emitted by SkFontMgr_config_parser). The proper fix is
+    # to pair a single OHOS/fontconfig factory with config_parser — handled in the
+    # render/font-backend stage, not the compile gate.
     sources -= [ "src/ports/SkFontMgr_custom_directory_factory.cpp" ]
   }
 }
@@ -709,9 +714,10 @@ skia_source_set("typeface_proxy") {
 }
 
 optional("fontmgr_fontconfig") {
