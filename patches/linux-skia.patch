     enabled = false
   } else {
+    # Linux/Wayland native port: arkui-x desktop client uses the fontconfig SkFontMgr.
     enabled = skia_enable_fontmgr_fontconfig
   }
   public_defines = [ "SK_FONTMGR_FONTCONFIG_AVAILABLE" ]
@@ -892,9 +898,12 @@ optional("fontmgr_win_factory") {
 
 
 optional("fontmgr_fontconfig_factory") {
-  if (use_oh_skia) {
+  if (use_oh_skia && !(is_arkui_x && target_os == "linux")) {
     enabled = false
   } else {
+    # Linux/Wayland native port: the arkui-x desktop client uses the fontconfig
+    # SkFontMgr::Factory() even though use_oh_skia is set (the OHOS factory is
+    # removed for is_arkui_x).
     enabled = skia_enable_fontmgr_fontconfig
