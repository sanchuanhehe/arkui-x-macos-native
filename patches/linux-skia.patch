-  skia_use_fontconfig = is_linux
+
+  # Linux/Wayland native port: the arkui-x desktop client uses fontconfig for its
+  # SkFontMgr (the OHOS skia path's font factory is removed for is_arkui_x, leaving
+  # SkFontMgr::Factory() undefined). is_linux is false under the OHOS BUILDCONFIG, so
+  # key off target_os.
+  skia_use_fontconfig = is_linux || (is_arkui_x && target_os == "linux")
   skia_use_fontations = false
   skia_use_fonthost_mac = is_mac || is_ios
   skia_use_freetype = is_android || is_fuchsia || is_linux || is_wasm
@@ -150,9 +155,16 @@ declare_args() {
