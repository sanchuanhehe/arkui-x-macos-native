diff --git a/adapter/preview/build/config_mac.gni b/adapter/preview/build/config_mac.gni
index 5bdfafed3cd..1e4f247fa9e 100644
--- a/adapter/preview/build/config_mac.gni
+++ b/adapter/preview/build/config_mac.gni
@@ -12,9 +12,99 @@
 # limitations under the License.
 
 import("preview_common.gni")
+import(
+    "//foundation/graphic/graphic_2d/rosen/modules/render_service_base/config.gni")
 
 # windows platform defines and configs
 defines += [
   "MAC_PLATFORM",
   "SK_BUILD_FONT_MGR_FOR_PREVIEW_MAC",
+
+  # Phase 0 path X: bounds_checking_function securectype.h leaves
+  # SECUREC_ENABLE_SNPRINTF/VSNPRINTF at 0 on non-MSVC (mac), so securec.h hides
+  # snprintf_s/vsnprintf_s. Many libace TUs (ace ios_trace.cpp, graphic_2d
+  # rs_dfx_string.h, ...) call them. The bounds_checking lib implements them; just
+  # turn the declarations on for the mac build.
+  "SECUREC_ENABLE_SNPRINTF=1",
+  "SECUREC_ENABLE_VSNPRINTF=1",
 ]
+
+# Phase 1 path X: the macOS desktop build uses the appframework (iOS-style)
+# backend, not the previewer. The "PREVIEW" define (from preview_common.gni)
+# collides with enum identifiers in image_framework (e.g. Cr3UuidType::PREVIEW),
+# so drop it for the native-mac build.
+# Phase 0 path X: the native-mac (appframework/iOS-style) backend is NOT the
+# previewer, so PREVIEW must be dropped. It was previously only removed under
+# preview_support, but PREVIEW (added by preview_common.gni) leaks into the macos
+# adapter TUs regardless. With PREVIEW set, JsMessageDispatcher::CallCurlFunction
+# becomes a pure virtual that AceContainerSG does not implement -> "allocating an
+# object of abstract class type 'AceContainerSG'". Remove it whenever the iOS-style
+# backend is active (and still under the old preview_support path for safety).
+if ((defined(mac_use_ios_backend) && mac_use_ios_backend) ||
+    (defined(preview_support) && preview_support)) {
+  if (filter_include(defines, [ "PREVIEW" ]) != []) {
+    defines -= [ "PREVIEW" ]
+  }
+}
+
+# Phase 2 path X (M1): wire the native-macOS adapter into libace so the ace_engine
+# framework picks up the macos entrance/osal/stage/uicontent targets (mirrors
+# adapter/ios/build/config.gni). Also turn on the iOS-style feature defines so the
+# ~45 IOS_PLATFORM code branches are reused (mac defines both IOS_PLATFORM and
+# MAC_PLATFORM; real UIKit/AppKit divergences are split on MAC_PLATFORM).
+if (defined(mac_use_ios_backend) && mac_use_ios_backend) {
+  # Path X is the appframework/iOS-style backend, not the previewer.
+  build_for_preview = false
+
+  # Static ICU like iOS (the shared ICU isn't built for the standalone app; the
+  # static target also supplies the unicode/* include path).
+  use_external_icu = "static"
+
+  defines += [
+    "IOS_PLATFORM",
+    # Phase 0 path X: mirror adapter/ios/build/config.gni — CROSS_PLATFORM gates
+    # the cross-platform InputMethodManager method declarations (ShowKeyboard /
+    # SetEditingState / Attach / ...) in core/common/ime/input_method_manager.h;
+    # without it the macos osal input_method_manager_ios.cpp out-of-line defs do
+    # not match any declaration.
+    "CROSS_PLATFORM",
+    # Phase 0 path X: mirror adapter/ios/build/config.gni — NG_BUILD selects the
+    # new (NG) pipeline frontend. ace_container_sg.cpp instantiates
+    # DeclarativeFrontendNG; without NG_BUILD the NG frontend delegate header is
+    # compiled out and the type is unknown.
+    "NG_BUILD",
+    "VIRTUAL_RS_WINDOW",
+    "ENABLE_ROSEN_BACKEND",
+    "QUICK_PUSH_TRANSITION",
+    "ACE_ENABLE_GL",
+
+    # Phase 0 path X: the macos uicontent reuses the iOS ace_view_sg.cpp, which
+    # calls PipelineBase::OnTouchTargetHitTest — a method declared only under
+    # #if defined(SUPPORT_TOUCH_TARGET_TEST). iOS turns this on via its config
+    # (support_touch_target_test); mirror it for mac.
+    "SUPPORT_TOUCH_TARGET_TEST",
+  ]
+
+  # Replace the previewer platform_deps (set in preview_common.gni) with the
+  # native-mac adapter targets.
+  platform_deps = []
+  platform_deps = [
+    "//foundation/arkui/ace_engine/adapter/macos/entrance:ace_macos_entrance",
+    "//foundation/arkui/ace_engine/adapter/macos/osal:ace_osal_mac",
+    "//foundation/arkui/ace_engine/adapter/macos/stage/ability:stage_macos_entrance",
+    "//foundation/arkui/ace_engine/adapter/macos/stage/uicontent:ace_uicontent_mac",
+  ]
+
+  # libace_static_mac is already generated by ace_engine/build/BUILD.gn's
+  # foreach over ace_platforms; the macos platform_deps above are pulled into it
+  # via ace_lib.gni.
+  libace_target = "//foundation/arkui/ace_engine/build:libace_static_mac"
+
+  # Phase 0 path X: drop PREVIEW at the very end of the mac iOS-backend config
+  # (after every import/define above). PREVIEW makes JsMessageDispatcher::
+  # CallCurlFunction a pure virtual that AceContainerSG never implements
+  # ("allocating an object of abstract class type 'AceContainerSG'").
+  if (filter_include(defines, [ "PREVIEW" ]) != []) {
+    defines -= [ "PREVIEW" ]
+  }
+}
