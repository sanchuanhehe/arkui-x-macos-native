diff --git a/toolchain/mac/BUILD.gn b/toolchain/mac/BUILD.gn
new file mode 100644
index 0000000..f88f234
--- /dev/null
+++ b/toolchain/mac/BUILD.gn
@@ -0,0 +1,316 @@
+# Copyright (c) 2026 Huawei Device Co., Ltd.
+# Licensed under the Apache License, Version 2.0 (the "License");
+# you may not use this file except in compliance with the License.
+# You may obtain a copy of the License at
+#
+#     http://www.apache.org/licenses/LICENSE-2.0
+#
+# Unless required by applicable law or agreed to in writing, software
+# distributed under the License is distributed on an "AS IS" BASIS,
+# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+# See the License for the specific language governing permissions and
+# limitations under the License.
+
+# Phase 0: native macOS (AppKit) desktop toolchain. This is a near-clone of
+# build_plugins/toolchain/ios/BUILD.gn. The ios toolchain template already
+# builds host-side targets with current_os="mac" (see ios_clang_x64), proving
+# the clang/ld/linker_driver plumbing works for the desktop. The only real
+# difference here is the sysroot: we point at the macosx SDK and pass
+# -mmacosx-version-min instead of -miphoneos-version-min.
+
+import("//build/config/clang/clang.gni")
+import("//build/config/mac/mac_sdk.gni")
+import("//build/config/mac/symbols.gni")
+import("//build_plugins/config/mac/mac_sdk.gni")
+
+assert(host_os == "mac")
+
+import("//build/toolchain/cc_wrapper.gni")
+import("//build/toolchain/clang_static_analyzer.gni")
+import("//build/toolchain/toolchain.gni")
+
+tool_versions =
+    exec_script("get_tool_mtime.py",
+                rebase_path([
+                              "//build_plugins/toolchain/mac/filter_libtool.py",
+                              "//build_plugins/toolchain/mac/linker_driver.py",
+                            ],
+                            root_build_dir),
+                "trim scope")
+
+# Shared toolchain definition. Invocations should set current_os to set the
+# build args in this definition.
+template("mac_desktop_toolchain") {
+  toolchain(target_name) {
+    if (use_system_xcode) {
+      env_wrapper = ""
+    } else {
+      env_wrapper = "export DEVELOPER_DIR=$hermetic_xcode_path; "
+    }
+
+    assert(defined(invoker.toolchain_args),
+           "Toolchains must declare toolchain_args")
+    toolchain_args = {
+      forward_variables_from(invoker.toolchain_args, "*")
+      host_toolchain = host_toolchain
+    }
+
+    # Use the version of clang shipped with Xcode when use_xcode_clang is set,
+    # otherwise use the prebuilt clang. The macOS SDK's Objective-C headers are
+    # matched to the system clang and do NOT compile with the prebuilt OHOS
+    # clang-15 (NSUInteger unknown), so the desktop build requires Xcode's clang.
+    # Use an absolute path because build.sh prepends prebuilts/ to PATH.
+    if (use_xcode_clang) {
+      prefix = "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/"
+
+      # alink uses Apple libtool in this path, not _ar; keep a value to satisfy
+      # references below without GN flagging an unused assignment.
+      _ar = "${prefix}ar"
+    } else {
+      prefix = rebase_path("$clang_base_path/bin/", root_build_dir)
+      _ar = "${prefix}llvm-ar"
+    }
+    not_needed([ "_ar" ])
+
+    _cc = "${prefix}clang"
+    _cxx = "${prefix}clang++"
+
+    if (defined(toolchain_args.cc_wrapper)) {
+      toolchain_cc_wrapper = toolchain_args.cc_wrapper
+    } else {
+      toolchain_cc_wrapper = cc_wrapper
+    }
+
+    if (toolchain_cc_wrapper != "") {
+      compiler_prefix = toolchain_cc_wrapper + " "
+    } else {
+      compiler_prefix = ""
+    }
+
+    cc = compiler_prefix + _cc
+    cxx = compiler_prefix + _cxx
+    ld = _cxx
+
+    if (use_clang_static_analyzer) {
+      analyzer_wrapper =
+          rebase_path("//build/toolchain/clang_static_analyzer_wrapper.py",
+                      root_build_dir) + "  --mode=clang"
+      cc = analyzer_wrapper + " ${cc}"
+      cxx = analyzer_wrapper + " ${cxx}"
+      ld = cxx
+    }
+
+    linker_driver =
+        "TOOL_VERSION=${tool_versions.linker_driver} " +
+        rebase_path("//build_plugins/toolchain/mac/linker_driver.py",
+                    root_build_dir)
+
+    _save_unstripped_output = false
+
+    lib_switch = "-l"
+    lib_dir_switch = "-L"
+
+    object_subdir = "{{source_out_dir}}/{{label_name}}"
+
+    if (_save_unstripped_output) {
+      _unstripped_output = "{{root_out_dir}}/{{target_output_name}}{{output_extension}}.unstripped"
+    }
+
+    sysroot_flags = ""
+    if (defined(invoker.sysroot_flags)) {
+      sysroot_flags = invoker.sysroot_flags
+    }
+    tool("cc") {
+      depfile = "{{output}}.d"
+      precompiled_header_type = "gcc"
+      command = "$cc -MMD -MF $depfile {{defines}} {{include_dirs}} $sysroot_flags {{cflags}} {{cflags_c}} -c {{source}} -o {{output}}"
+      depsformat = "gcc"
+      description = "CC {{output}}"
+      outputs = [ "$object_subdir/{{source_name_part}}.o" ]
+    }
+
+    tool("cxx") {
+      depfile = "{{output}}.d"
+      precompiled_header_type = "gcc"
+      command = "$cxx -MMD -MF $depfile {{defines}} {{include_dirs}} $sysroot_flags {{cflags}} {{cflags_cc}} -c {{source}} -o {{output}}"
+      depsformat = "gcc"
+      description = "CXX {{output}}"
+      outputs = [ "$object_subdir/{{source_name_part}}.o" ]
+    }
+
+    tool("asm") {
+      depfile = "{{output}}.d"
+      command = "$cc -MMD -MF $depfile {{defines}} {{include_dirs}} {{asmflags}} $sysroot_flags -c {{source}} -o {{output}}"
+      depsformat = "gcc"
+      description = "ASM {{output}}"
+      outputs = [ "$object_subdir/{{source_name_part}}.o" ]
+    }
+
+    tool("objc") {
+      depfile = "{{output}}.d"
+      precompiled_header_type = "gcc"
+      command = "$cc -MMD -MF $depfile {{defines}} {{include_dirs}} {{framework_dirs}} $sysroot_flags {{cflags}} {{cflags_objc}} -c {{source}} -o {{output}}"
+      depsformat = "gcc"
+      description = "OBJC {{output}}"
+      outputs = [ "$object_subdir/{{source_name_part}}.o" ]
+    }
+
+    tool("objcxx") {
+      depfile = "{{output}}.d"
+      precompiled_header_type = "gcc"
+      command = "$cxx -MMD -MF $depfile {{defines}} {{include_dirs}} {{framework_dirs}} $sysroot_flags {{cflags}} {{cflags_objcc}} -c {{source}} -o {{output}}"
+      depsformat = "gcc"
+      description = "OBJCXX {{output}}"
+      outputs = [ "$object_subdir/{{source_name_part}}.o" ]
+    }
+
+    tool("alink") {
+      rspfile = "{{output}}.rsp"
+
+      # Phase 1 path X: Xcode's BSD ar supports neither -D nor @rspfile, and
+      # neither ar nor libtool will create an EMPTY archive (header-only targets).
+      # Use Apple libtool when there are inputs; otherwise synthesize an empty but
+      # valid archive from a throwaway object.
+      if (use_xcode_clang) {
+        command = "rm -f {{output}} && if [ -s \"$rspfile\" ]; then /usr/bin/libtool -static -o {{output}} -filelist \"$rspfile\"; else _e=\"{{output}}.empty\"; echo '' | xcrun clang -x c -c - -o \"\${_e}.o\" && /usr/bin/libtool -static -o {{output}} \"\${_e}.o\" && rm -f \"\${_e}.o\"; fi"
+      } else {
+        command = "rm -f {{output}} && $_ar {{arflags}} -r -c -s -D {{output}} \"@$rspfile\""
+      }
+      rspfile_content = "{{inputs_newline}}"
+      description = "AR {{output}}"
+      outputs = [ "{{output_dir}}/{{target_output_name}}{{output_extension}}" ]
+      default_output_dir = "{{target_out_dir}}"
+      default_output_extension = ".a"
+      output_prefix = "lib"
+    }
+
+    tool("solink") {
+      dylib = "{{output_dir}}/{{target_output_name}}{{output_extension}}"
+      rspfile = dylib + ".rsp"
+      pool = "//build/toolchain:link_pool($default_toolchain)"
+
+      tocname = dylib + ".TOC"
+      temporary_tocname = dylib + ".tmp"
+
+      does_reexport_command = "[ ! -e \"$dylib\" -o ! -e \"$tocname\" ] || otool -l \"$dylib\" | grep -q LC_REEXPORT_DYLIB"
+
+      llvm_strip =
+          rebase_path("$clang_base_path/bin/llvm-strip", root_build_dir)
+      unstripped_dylib_dir =
+          "{{root_out_dir}}/unstripped_dylib/{{target_output_name}}"
+      link_command = "$linker_driver $ld -shared $sysroot_flags "
+      if (is_component_build) {
+        link_command += " -Wl,-install_name,@rpath/\"{{target_output_name}}{{output_extension}}\" "
+      }
+      link_command += "{{ldflags}} -o \"$dylib\" -Wl,-filelist,\"$rspfile\" {{libs}} {{solibs}} {{frameworks}} "
+      link_command += " -Wcrl,strip,$llvm_strip"
+      link_command += " -Wcrl,unstripped,$unstripped_dylib_dir"
+
+      replace_command = "if ! cmp -s \"$temporary_tocname\" \"$tocname\"; then mv \"$temporary_tocname\" \"$tocname\""
+      extract_toc_command = "{ otool -l \"$dylib\" | grep LC_ID_DYLIB -A 5; nm -gP \"$dylib\" | cut -f1-2 -d' ' | grep -v U\$\$; true; }"
+
+      command = "$env_wrapper if $does_reexport_command ; then $link_command && $extract_toc_command > \"$tocname\"; else $link_command && $extract_toc_command > \"$temporary_tocname\" && $replace_command ; fi; fi"
+
+      rspfile_content = "{{inputs_newline}}"
+
+      description = "SOLINK {{output}}"
+
+      default_output_dir = "{{root_out_dir}}"
+      default_output_extension = ".dylib"
+
+      output_prefix = "lib"
+
+      restat = true
+
+      outputs = [
+        dylib,
+        tocname,
+      ]
+      link_output = dylib
+      depend_output = tocname
+
+      if (_save_unstripped_output) {
+        outputs += [ _unstripped_output ]
+      }
+    }
+
+    tool("solink_module") {
+      sofile = "{{output_dir}}/{{target_output_name}}{{output_extension}}"
+      rspfile = sofile + ".rsp"
+      pool = "//build/toolchain:link_pool($default_toolchain)"
+
+      link_command = "$env_wrapper $linker_driver $ld -bundle {{ldflags}} -o \"$sofile\" -Wl,-filelist,\"$rspfile\""
+      if (is_component_build) {
+        link_command += " -Wl,-install_name,@rpath/{{target_output_name}}{{output_extension}}"
+      }
+      link_command += " {{solibs}} {{libs}}"
+      command = link_command
+
+      rspfile_content = "{{inputs_newline}}"
+
+      description = "SOLINK_MODULE {{output}}"
+
+      default_output_dir = "{{root_out_dir}}"
+      default_output_extension = ".so"
+
+      outputs = [ sofile ]
+
+      if (_save_unstripped_output) {
+        outputs += [ _unstripped_output ]
+      }
+    }
+
+    tool("link") {
+      outfile = "{{output_dir}}/{{target_output_name}}{{output_extension}}"
+      rspfile = "$outfile.rsp"
+      pool = "//build/toolchain:link_pool($default_toolchain)"
+
+      command = "$env_wrapper $linker_driver $ld $sysroot_flags {{ldflags}} -o \"$outfile\" -Wl,-filelist,\"$rspfile\" {{solibs}} {{libs}} {{frameworks}} "
+      description = "LINK $outfile"
+      rspfile_content = "{{inputs_newline}}"
+      outputs = [ outfile ]
+
+      if (_save_unstripped_output) {
+        outputs += [ _unstripped_output ]
+      }
+
+      default_output_dir = "{{root_out_dir}}"
+    }
+
+    tool("stamp") {
+      command = stamp_command
+      description = stamp_description
+    }
+    tool("copy") {
+      command = copy_command
+      description = copy_description
+    }
+
+    tool("copy_bundle_data") {
+      command = "rm -rf {{output}} && cp -af {{source}} {{output}}"
+      description = "copy_bundle_data {{source}} {{output}}"
+    }
+
+    tool("action") {
+      pool = "//build/toolchain:action_pool($default_toolchain)"
+    }
+  }
+}
+
+# Native macOS desktop (Apple Silicon).
+mac_desktop_toolchain("mac_clang_arm64") {
+  toolchain_args = {
+    current_cpu = "arm64"
+    current_os = "mac"
+  }
+  sysroot_flags = "-isysroot $mac_desktop_sdk_path -target arm64-apple-macos$mac_deployment_target"
+}
+
+# Native macOS desktop (Intel), for completeness / Rosetta hosts.
+mac_desktop_toolchain("mac_clang_x64") {
+  toolchain_args = {
+    current_cpu = "x64"
+    current_os = "mac"
+  }
+  sysroot_flags = "-isysroot $mac_desktop_sdk_path -target x86_64-apple-macos$mac_deployment_target"
+}
diff --git a/toolchain/mac/filter_libtool.py b/toolchain/mac/filter_libtool.py
new file mode 100755
index 0000000..d79f664
--- /dev/null
+++ b/toolchain/mac/filter_libtool.py
@@ -0,0 +1,55 @@
+#!/usr/bin/env python
+# -*- coding: utf-8 -*-
+# Copyright 2016 The Chromium Authors. All rights reserved.
+# Use of this source code is governed by a BSD-style license that can be
+# found in the LICENSE file.
+
+import os
+import re
+import subprocess
+import sys
+
+# This script executes libtool and filters out logspam lines like:
+#    '/path/to/libtool: file: foo.o has no symbols'
+BLOCKLIST_PATTERNS = map(re.compile, [
+    r'^.*libtool: (?:for architecture: \S* )?file: .* has no symbols$',
+    r'^.*libtool: warning for library: .* the table of contents is empty '
+    r'\(no object file members in the library define global symbols\)$',
+    r'^.*libtool: warning same member name \(\S*\) in output file used for '
+    r'input files: \S* and: \S* \(due to use of basename, truncation, '
+    r'blank padding or duplicate input files\)$',
+])
+
+
+def is_blocklisted_line(line):
+    """Returns whether the line should be filtered out."""
+    for pattern in BLOCKLIST_PATTERNS:
+        if isinstance(line, bytes):
+            line = line.decode()
+        if pattern.match(line):
+            return True
+    return False
+
+
+def main(cmd_list):
+    env = os.environ.copy()
+    # The problem with this flag is that it resets the file mtime on the file
+    # to epoch=0, e.g. 1970-1-1 or 1969-12-31 depending on timezone.
+    env['ZERO_AR_DATE'] = '1'
+    libtoolout = subprocess.Popen(cmd_list, stderr=subprocess.PIPE, env=env)
+    _, err = libtoolout.communicate()
+    for line in err.splitlines():
+        if not is_blocklisted_line(line):
+            print(line, file=sys.stderr)
+    # Unconditionally touch the output .a file on the command line if present
+    # and the command succeeded. A bit hacky.
+    if not libtoolout.returncode:
+        for i in range(len(cmd_list) - 1):
+            if cmd_list[i] == '-o' and cmd_list[i + 1].endswith('.a'):
+                os.utime(cmd_list[i + 1], None)
+                break
+    return libtoolout.returncode
+
+
+if __name__ == '__main__':
+    sys.exit(main(sys.argv[1:]))
