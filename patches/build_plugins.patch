+# Phase 0: macOS desktop SDK args. Parallels build_plugins/config/ios/ios_sdk.gni
+# but targets the native "macosx" SDK so the darwin RenderService backend can be
+# compiled for target_os=mac.
+
+# mac_deployment_target is already declared in //build/config/mac/mac_sdk.gni;
+# do not redeclare it here (gn forbids duplicate build-arg declarations).
+declare_args() {
